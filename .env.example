PORT=3000
HOST=127.0.0.1

# Meta WhatsApp Cloud API
WHATSAPP_VERIFY_TOKEN=choose-a-long-random-string
# Token from Graph API Explorer expires in ~1h — not for production.
# ~60 days: create a long-lived user token (exchange short-lived with app id+secret; refresh before expiry).
# Best for always-on bots: Meta Business Settings → System users → app → generate token (WhatsApp permissions).
WHATSAPP_ACCESS_TOKEN=replace-with-meta-access-token
WHATSAPP_PHONE_NUMBER_ID=replace-with-phone-number-id
WHATSAPP_GRAPH_API_VERSION=v24.0

# Optional but strongly recommended. Found in your Meta app settings.
META_APP_SECRET=

# Restrict the assistant to only your WhatsApp sender ID/phone number.
# Leave blank during first webhook testing, then set it after you see your sender ID in logs.
OWNER_WHATSAPP_ID=

# LLM: openai | anthropic | ollama
LLM_PROVIDER=ollama

# OpenAI (when LLM_PROVIDER=openai)
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_MODEL=gpt-5.1

# Anthropic / Claude (when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=replace-with-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Ollama (when LLM_PROVIDER=ollama) — free, runs on your Mac; no API key / no hourly expiry
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
# Optional: semantic memory retrieval (pull model first: ollama pull nomic-embed-text)
# Works with any LLM_PROVIDER — embeddings always use Ollama on OLLAMA_BASE_URL.
# OLLAMA_EMBED_MODEL=nomic-embed-text
# MEMORY_RETRIEVAL_TOP_K=12
# MEMORY_RETRIEVAL_MIN_FACTS=8
# Max new tokens per reply (higher = longer answers; slower)
# OLLAMA_NUM_PREDICT=1200

# Answer depth: thorough (default — substantive, still non-cheerleader) | brief | whatsapp (shorter)
ASSISTANT_STYLE=thorough

# Cloud models are much broader than small local Ollama — use LLM_PROVIDER=openai or anthropic for closest ChatGPT feel

# Local memory storage
MEMORY_FILE=./data/memory.json
CONVERSATION_HISTORY_LIMIT=10
CONVERSATION_MAX_CHARS=600
AUTO_LEARN_FACTS=true

# Local wall clock shown to the model (for "what time is it" — server time in this zone)
USER_TIMEZONE=Australia/Sydney
DEDUP_FILE=./data/processed-message-ids.json

# Finance skills (RSS + Reddit) — no API keys required for defaults
# Optional: Name|URL pairs separated by commas
# FINANCE_RSS_FEEDS=ECB|https://www.ecb.europa.eu/rss/press.html,Fed|https://www.federalreserve.gov/feeds/press_all.xml
REDDIT_SUBREDDITS=investing,stocks,economics,SecurityAnalysis
REDDIT_USER_AGENT=personal-whatsapp-assistant/0.1

# Web search (Brave Search API — https://brave.com/search/api/)
BRAVE_API_KEY=replace-with-brave-api-key
BRAVE_SEARCH_COUNT=8
# When BRAVE_API_KEY is set, infer questions that need the web (set false to disable all auto-search)
AUTO_WEB_SEARCH=true
# easy (default) — restaurants, reviews, factual questions, + time-sensitive phrases
# conservative — only "latest / today / 2025…" style triggers
# explicit — never auto; only messages starting with search / google / lookup
WEB_SEARCH_CHAT_MODE=easy
# Optional ISO country code (e.g. AU) to bias results
# BRAVE_SEARCH_COUNTRY=AU
